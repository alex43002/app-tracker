{
  "manifest_version": 3,
  "name": "CareerLog Job Saver",
  "version": "0.1.0",
  "description": "Save a job posting from any career page straight into your CareerLog tracker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save this job to CareerLog"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
